""Short-term momentum bot: rising recent closes -> BUY, falling -> SELL."""

from collections import deque


class Bot:
    def __init__(self):
        self.fast_n = 5
        self.slow_n = 15
        self.max_history = 40
        self.recent_closes = deque(maxlen=self.max_history)
        self.trade_qty = 100
        self.max_long = 2500
        self.max_short = 1200
        self.signal_deadband = 0.00012

    def _avg(self, values):
        if not values:
            return None
        return sum(values) / len(values)

    def get_action(self, tick, cash, inventory):
        close = float(tick["close"])
        self.recent_closes.append(close)

        if len(self.recent_closes) < self.slow_n:
            return {"action": "HOLD", "quantity": 0}

        closes = list(self.recent_closes)
        fast_avg = self._avg(closes[-self.fast_n :])
        slow_avg = self._avg(closes[-self.slow_n :])

        if fast_avg is None or slow_avg is None or slow_avg <= 0:
            return {"action": "HOLD", "quantity": 0}

        rel_spread = (fast_avg - slow_avg) / slow_avg
        fee = 0.001
        min_cushion = close * self.trade_qty * (1.0 + fee) * 1.01

        if rel_spread > self.signal_deadband:
            if inventory >= self.max_long or cash < min_cushion:
                return {"action": "HOLD", "quantity": 0}
            return {"action": "BUY", "quantity": self.trade_qty}

        if rel_spread < -self.signal_deadband:
            if inventory <= -self.max_short:
                return {"action": "HOLD", "quantity": 0}
            return {"action": "SELL", "quantity": self.trade_qty}

        return {"action": "HOLD", "quantity": 0}
