"""
Local backtest engine + data inspection + multi-bot benchmark.

Requires: pandas, numpy, train_data.csv (same folder), bot_template.py,
  bot_momentum.py, bot_meanrev.py

  python engine.py                 # full train_data.csv + write benchmark_results.md
  python engine.py --limit 50000   # first N rows only
"""

from __future__ import annotations

import argparse
import time
from pathlib import Path

import numpy as np
import pandas as pd

import bot_meanrev as br
import bot_momentum as bm
import bot_template as bt

HERE = Path(__file__).resolve().parent
CSV_PATH = HERE / "train_data.csv"
OUT_MD = HERE / "benchmark_results.md"


def run_local_engine(team_bot, test_data):
    cash = 100000.0
    inventory = 0
    fee = 0.001
    executed = 0
    rejected = 0
    timeouts = 0

    for tick in test_data:
        price = tick["close"]
        current_buying_power = cash + (inventory * price)

        if current_buying_power <= 0:
            print("MARGIN CALL: You went bankrupt!")
            return {
                "Final_Value": 0,
                "Executed": executed,
                "Rejected": rejected,
                "Timeouts": timeouts,
                "Status": "BANKRUPT",
            }

        try:
            start = time.perf_counter()
            entscheidung = team_bot.get_action(tick, cash, inventory)
            duration = time.perf_counter() - start
        except Exception:
            timeouts += 1
            continue

        if duration > 0.03:
            timeouts += 1
            continue

        act = entscheidung.get("action")
        qty = entscheidung.get("quantity", 0)
        cost = qty * price

        if act == "BUY" and qty > 0:
            new_inv = inventory + qty
            if cash >= (cost * (1 + fee)) and abs(new_inv * price) <= current_buying_power:
                cash -= cost * (1 + fee)
                inventory = new_inv
                executed += 1
            else:
                rejected += 1

        elif act == "SELL" and qty > 0:
            new_inv = inventory - qty
            if abs(new_inv * price) <= current_buying_power:
                cash += cost * (1 - fee)
                inventory = new_inv
                executed += 1
            else:
                rejected += 1

    final_value = cash + (inventory * test_data[-1]["close"])

    return {
        "Final_Value": round(final_value, 2),
        "Executed": executed,
        "Rejected": rejected,
        "Timeouts": timeouts,
        "Status": "COMPLETED",
    }


def inspect_data(df: pd.DataFrame) -> dict:
    c = df["close"].astype(float)
    h = df["high"].astype(float)
    l = df["low"].astype(float)
    v = df["volume"].astype(float)

    ret = c.pct_change().dropna()
    total_ret = float(c.iloc[-1] / c.iloc[0] - 1.0)
    x = np.arange(len(c), dtype=float)
    slope = float(np.polyfit(x, c.values, 1)[0])

    hl = h - l
    vol_1m = float(ret.std())
    ann_approx = vol_1m * np.sqrt(252 * 390)

    abs_next = ret.abs().shift(-1)
    lag_corrs = {lag: float(v.shift(lag).corr(abs_next)) for lag in range(1, 6)}

    sign = np.sign(ret.values)
    flips = (sign[1:] * sign[:-1] < 0).mean() if len(sign) > 1 else np.nan
    ac1 = float(ret.autocorr(lag=1)) if len(ret) > 1 else np.nan

    return {
        "rows": len(df),
        "first_close": float(c.iloc[0]),
        "last_close": float(c.iloc[-1]),
        "total_return_frac": total_ret,
        "close_poly_slope_per_bar": slope,
        "ret_std_1bar": vol_1m,
        "ret_ann_vol_approx_sqrt252x390": float(ann_approx),
        "hl_mean": float(hl.mean()),
        "hl_median": float(hl.median()),
        "hl_mean_over_close_mean": float((hl / c).mean()),
        "volume_absret_corr_lag": lag_corrs,
        "sign_flip_rate": float(flips),
        "ret_autocorr_lag1": ac1,
    }


def notes_for_version(version: str, r: dict) -> str:
    if r.get("Status") == "BANKRUPT":
        return "Bankrupt (margin)."
    if version == "baseline":
        return "Buys while cash>5k and close<100; sells 5 on volume>150 when long; very active, fee-heavy."
    if version == "v1 momentum":
        return "Fast>slow avg + deadband; chases short-term drift; long/short capped."
    if version == "v2 mean reversion":
        return "Fade vs SMA band; expects snapback; long/short capped."
    return ""


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--limit", type=int, default=None, help="Only first N rows")
    args = parser.parse_args()

    print(f"Loading {CSV_PATH} ...")
    t_load = time.perf_counter()
    df = pd.read_csv(CSV_PATH, sep=";")
    if args.limit is not None:
        df = df.head(args.limit)
        print(f"Using first {len(df):,} rows (--limit).")
    print(f"Loaded {len(df):,} rows in {time.perf_counter() - t_load:.2f}s")

    print("Inspecting data...")
    stats = inspect_data(df)
    market_data = df.to_dict("records")

    bots = [
        ("baseline", "template bot", bt.Bot()),
        ("v1 momentum", "Person 1 momentum", bm.Bot()),
        ("v2 mean reversion", "Person 2 mean reversion", br.Bot()),
    ]

    rows_out = []
    print("\nRunning backtests...")
    for version, idea, bot in bots:
        t0 = time.perf_counter()
        r = run_local_engine(bot, market_data)
        wall = time.perf_counter() - t0
        note = notes_for_version(version, r)
        rows_out.append(
            {
                "Version": version,
                "Idea": idea,
                "Final Value": r["Final_Value"],
                "Executed": r["Executed"],
                "Rejected": r["Rejected"],
                "Timeouts": r["Timeouts"],
                "Status": r.get("Status", ""),
                "Notes": note,
                "Wall_s": round(wall, 2),
            }
        )
        print(f"  {version}: Final={r['Final_Value']} Exec={r['Executed']} ({wall:.2f}s)")

    lines = []
    lines.append("# Train data + bot benchmark\n")
    lines.append("## Data inspection\n\n")
    lines.append(f"- **Rows:** {stats['rows']:,}\n")
    lines.append(
        f"- **Price:** first close {stats['first_close']:.6f}, last {stats['last_close']:.6f} "
        f"(**total return** {stats['total_return_frac'] * 100:.4f}%)\n"
    )
    lines.append(
        f"- **Trend (linear):** slope of close vs bar index ≈ **{stats['close_poly_slope_per_bar']:.2e}** per bar.\n"
    )
    lines.append(
        f"- **Volatility:** 1-bar return std ≈ **{stats['ret_std_1bar']:.6f}** "
        f"(crude annualization ~**{stats['ret_ann_vol_approx_sqrt252x390']:.4f}**).\n"
    )
    lines.append(
        f"- **Average (high−low):** mean **{stats['hl_mean']:.6f}**, median **{stats['hl_median']:.6f}**; "
        f"as fraction of close, mean **{stats['hl_mean_over_close_mean'] * 100:.4f}%**.\n"
    )
    lines.append("- **Volume vs upcoming |return|:** Pearson corr(volume lag k, |r[t+1]|):\n")
    for k, cor in stats["volume_absret_corr_lag"].items():
        lines.append(f"  - lag {k}: **{cor:.4f}**\n")
    lines.append(
        f"- **Reversals vs trends (rough):** sign flip rate **{stats['sign_flip_rate'] * 100:.2f}%**; "
        f"lag-1 autocorr of returns **{stats['ret_autocorr_lag1']:.4f}**.\n"
    )

    lines.append("\n## Answers\n\n")
    lines.append(
        "1. **Does price trend overall up or down?** "
        f"End-to-end return is **{'up' if stats['total_return_frac'] > 0 else 'down'}** "
        f"({stats['total_return_frac'] * 100:.4f}%).\n"
    )
    lines.append(
        "2. **Does volume spike before moves?** "
        "Corr(volume lag k, |r[t+1]|) is **moderately positive** in this file — see inspection table.\n"
    )
    lines.append(
        "3. **Long trends vs reversals?** "
        f"Sign flip rate **{stats['sign_flip_rate'] * 100:.1f}%**; lag-1 return autocorr **{stats['ret_autocorr_lag1']:.4f}** "
        "(near zero at 1 bar).\n"
    )

    lines.append("\n## Shared results table\n\n")
    lines.append(
        "| Version | Idea | Final Value | Executed | Rejected | Timeouts | Notes |\n"
        "|---|---|---:|---:|---:|---:|---|\n"
    )
    for row in rows_out:
        st = row.get("Status", "")
        note = row["Notes"]
        if st and st != "COMPLETED":
            note = f"{note} (Status: {st})"
        lines.append(
            f"| {row['Version']} | {row['Idea']} | {row['Final Value']} | {row['Executed']} | "
            f"{row['Rejected']} | {row['Timeouts']} | {note} |\n"
        )
    lines.append("\n_Wall times printed in console._\n")

    OUT_MD.write_text("".join(lines), encoding="utf-8")
    print(f"\nWrote {OUT_MD}")

    print("\n" + "=" * 100)
    print("Version\tIdea\tFinal Value\tExecuted\tRejected\tTimeouts\tNotes")
    for row in rows_out:
        print(
            f"{row['Version']}\t{row['Idea']}\t{row['Final Value']}\t{row['Executed']}\t"
            f"{row['Rejected']}\t{row['Timeouts']}\t{row['Notes']}"
        )
    print("=" * 100)


if __name__ == "__main__":
    main()
